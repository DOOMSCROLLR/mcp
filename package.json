{
  "name": "@doomscrollr/mcp-server",
  "version": "1.0.13",
  "mcpName": "com.doomscrollr/mcp",
  "description": "DOOMSCROLLR MCP server — AI agents build owned-audience websites, affiliate storefronts, product drops, newsletters, tickets, and subscriber capture for the audience layer of the AI agent world.",
  "main": "dist/index.js",
  "bin": {
    "doomscrollr-mcp": "dist/index.js",
    "doomscrollr-mcp-http": "dist/http.js"
  },
  "files": [
    "dist/",
    "widgets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test:widgets": "npm run build && node test/widgets.test.mjs",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "doomscrollr",
    "ai-agents",
    "creator-economy",
    "owned-audience",
    "content",
    "newsletter",
    "ecommerce"
  ],
  "author": "DOOMSCROLLR",
  "license": "MIT",
  "homepage": "https://mcp.doomscrollr.com",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DOOMSCROLLR/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/DOOMSCROLLR/mcp/issues"
  }
}
