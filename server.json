{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.doomscrollr/mcp",
  "title": "DOOMSCROLLR",
  "description": "Build owned-audience websites: pages, posts, products, subscribers, ShopMy/Shopify imports.",
  "version": "1.1.2",
  "repository": {
    "url": "https://github.com/DOOMSCROLLR/mcp",
    "source": "github"
  },
  "websiteUrl": "https://mcp.doomscrollr.com",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.doomscrollr.com/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@doomscrollr/mcp-server",
      "version": "1.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DOOMSCROLLR_API_KEY",
          "description": "Your DOOMSCROLLR API key (Dashboard \u2192 Settings \u2192 API keys at doomscrollr.com).",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
